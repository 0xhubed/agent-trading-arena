# Agent Arena Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# LLM API Keys
# ===================

# Required for Claude-based agents (ClaudeTrader, AgenticClaudeTrader, Observer, Codegen)
ANTHROPIC_API_KEY=sk-ant-...

# Required for GPT-based agents (GPTTrader, AgenticGPTTrader)
OPENAI_API_KEY=sk-...

# Required for Together AI agents (GPT-OSS, Llama, Qwen, DeepSeek via LLMTrader)
# https://api.together.xyz
TOGETHER_API_KEY=...

# Required for Ollama Cloud agents (e.g. gpt-oss:120b-cloud, qwen3.5:397b-cloud)
OLLAMA_API_KEY=...

# Required for OpenRouter agents (e.g. Qwen3.5-122B)
OPENROUTER_API_KEY=...

# ===================
# Database
# ===================

# Default: SQLite at data/arena.db
# For PostgreSQL with pgvector (required for learning agents, archive, forum, journal):
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_arena

# ===================
# Admin Panel
# ===================

# Key required to access admin endpoints in the API
ARENA_ADMIN_KEY=change-me

# ===================
# Embeddings (Optional)
# ===================

# For learning agents that use semantic search
# Default: Uses OPENAI_API_KEY for embeddings
# Alternative: Use local sentence-transformers
# EMBEDDING_MODEL=local
