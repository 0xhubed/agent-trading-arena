# Agent Arena Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# LLM API Keys
# ===================

# Required for Claude-based agents (ClaudeTrader, AgenticClaudeTrader, Observer Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Required for GPT-based agents (GPTTrader, AgenticGPTTrader)
OPENAI_API_KEY=sk-...

# Required for Together AI agents (TogetherTrader, Learning agents)
# Get your key at: https://api.together.xyz
TOGETHER_API_KEY=...

# ===================
# Database (Optional)
# ===================

# Default: SQLite at data/arena.db
# For PostgreSQL with pgvector (enables skill versioning):
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_arena

# ===================
# Embeddings (Optional)
# ===================

# For learning agents that use semantic search
# Default: Uses OPENAI_API_KEY for embeddings
# Alternative: Use local sentence-transformers
# EMBEDDING_MODEL=local
